# Exclude the standalone Hono API backend from Vercel deploys.
# It has its own Dockerfile and is deployed separately (Cloud Run / Render / etc).
# Next.js routes in src/app/api/v1/* serve the production API for this Vercel project.
# Leading slash is critical — without it, .vercelignore (gitignore syntax) would
# also match src/app/api/, removing all the Next.js routes.
/api/
