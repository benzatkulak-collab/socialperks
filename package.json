{
  "name": "social-perks",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "api:dev": "cd api && tsx watch src/index.ts",
    "api:start": "cd api && tsx src/index.ts",
    "api:test": "cd api && npx vitest run",
    "api:typecheck": "cd api && npx tsc --noEmit",
    "api:install": "cd api && npm install",
    "test:all": "vitest run && cd api && npx vitest run",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "db:migrate": "npx tsx scripts/db-migrate.ts",
    "db:migrate:status": "npx tsx scripts/db-migrate.ts --status",
    "db:migrate:dry": "npx tsx scripts/db-migrate.ts --dry-run"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "next": "^15.1.0",
    "postgres": "^3.4.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.1.0",
    "happy-dom": "^20.8.4",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  }
}
