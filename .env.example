# ═══════════════════════════════════════════════════════════════
# SOCIAL PERKS — Environment Configuration
# Copy this file to .env (or set on Vercel) and fill in real values.
#
# Severity legend:
#   [BLOCKING]   — runtime will throw or critical features 500 without it
#   [REQUIRED]   — needed before onboarding the first paying customer
#   [OPTIONAL]   — sensible default exists; set when you need the feature
#
# A go-live checklist for the first 10 coffee-shop customers is at the
# bottom of this file.
# ═══════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development                                                # [OPTIONAL]  development | production
# NEXT_PUBLIC_API_URL=                                              # [OPTIONAL]  Override API base URL for frontend client
# ALLOWED_ORIGINS=http://localhost:3000                             # [OPTIONAL]  CORS allow-list (comma-sep)

# ── Auth ─────────────────────────────────────────────────────
# Generate fresh values with: openssl rand -hex 32
AUTH_SECRET=                                                        # [BLOCKING]  JWT signing secret. Auth routes 500 without it in production.
CSRF_SECRET=                                                        # [BLOCKING]  CSRF token secret. Falls back to AUTH_SECRET if empty.

# ── Database ─────────────────────────────────────────────────
# When unset, the app uses an in-memory store that DROPS on restart.
# Acceptable for local dev; never for production.
# After setting, run: npm run db:migrate
DATABASE_URL=                                                       # [REQUIRED]  postgresql://user:pass@host:5432/db
# REDIS_URL=redis://localhost:6379                                  # [OPTIONAL]  Used by the Hono workspace; not needed for Next.js routes

# ── Stripe (billing + checkout) ──────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=                                                  # [REQUIRED]  sk_test_... for staging, sk_live_... for prod
STRIPE_WEBHOOK_SECRET=                                              # [REQUIRED]  whsec_... — see https://dashboard.stripe.com/webhooks
# Price IDs from your Stripe product catalog. Without these, /api/v1/billing
# returns mocked URLs and no money moves.
# STRIPE_PRICE_STARTER_MONTHLY=                                     # [OPTIONAL]  price_xxx
# STRIPE_PRICE_STARTER_ANNUAL=                                      # [OPTIONAL]
# STRIPE_PRICE_PROFESSIONAL_MONTHLY=                                # [OPTIONAL]
# STRIPE_PRICE_PROFESSIONAL_ANNUAL=                                 # [OPTIONAL]
# STRIPE_PRICE_ENTERPRISE_MONTHLY=                                  # [OPTIONAL]
# STRIPE_PRICE_ENTERPRISE_ANNUAL=                                   # [OPTIONAL]

# ── Email (Resend) ───────────────────────────────────────────
# Sign up at https://resend.com, verify your sending domain.
# Required for: waitlist confirmations, password resets, submission notices.
RESEND_API_KEY=                                                     # [REQUIRED]  re_...
EMAIL_FROM=Social Perks <noreply@socialperks.app>                   # [OPTIONAL]  Verified sender address
WAITLIST_NOTIFY_EMAIL=                                              # [OPTIONAL]  Where to send "new signup" pings (your inbox)
WAITLIST_ADMIN_TOKEN=                                               # [OPTIONAL]  Bearer token for GET /api/v1/waitlist (count peek)

# ── OAuth ────────────────────────────────────────────────────
# Canonical naming is OAUTH_<2-letter-platform-id>_CLIENT_ID/SECRET.
# Legacy long-form names (INSTAGRAM_CLIENT_ID, etc.) are still read as
# fallbacks for backwards compatibility.
#
# Platform IDs: ig=Instagram, fb=Facebook, tt=TikTok, xw=X, yt=YouTube,
#               li=LinkedIn, pi=Pinterest, th=Threads, sc=Snapchat,
#               tw=Twitch, rd=Reddit
#
# Until these are set, OAuth callbacks return mock tokens. That is safe
# for development but verification will not work against real platforms.

# Instagram (Meta Developer Portal → create app → Add Product: Instagram Basic)
# OAUTH_IG_CLIENT_ID=                                               # [REQUIRED for Instagram verification]
# OAUTH_IG_CLIENT_SECRET=                                           # [REQUIRED for Instagram verification]

# TikTok (https://developers.tiktok.com/apps)
# OAUTH_TT_CLIENT_ID=                                               # [REQUIRED for TikTok verification]
# OAUTH_TT_CLIENT_SECRET=                                           # [REQUIRED for TikTok verification]

# Facebook (Meta Developer Portal)
# OAUTH_FB_CLIENT_ID=                                               # [OPTIONAL]
# OAUTH_FB_CLIENT_SECRET=                                           # [OPTIONAL]

# X / Twitter (https://developer.twitter.com)
# OAUTH_XW_CLIENT_ID=                                               # [OPTIONAL]
# OAUTH_XW_CLIENT_SECRET=                                           # [OPTIONAL]

# YouTube / Google (https://console.cloud.google.com)
# OAUTH_YT_CLIENT_ID=                                               # [OPTIONAL]
# OAUTH_YT_CLIENT_SECRET=                                           # [OPTIONAL]

# ── Webhooks (platform → us) ─────────────────────────────────
# Used by /api/v1/verification/webhook for Meta-style hub.challenge
# verification and incoming event signature checks.
# WEBHOOK_VERIFY_TOKEN=                                             # [REQUIRED for production webhooks]
# WEBHOOK_SECRET=                                                   # [REQUIRED for production webhooks]

# ═══════════════════════════════════════════════════════════════
# GO-LIVE CHECKLIST — first 10 coffee-shop customers
# ═══════════════════════════════════════════════════════════════
# Step 1 — Get the site safely live
#   ☐ AUTH_SECRET set on Vercel (production + preview)
#   ☐ CSRF_SECRET set on Vercel (production + preview)
#   ☐ Vercel SSO Deployment Protection turned OFF (so prospects can see it)
#
# Step 2 — Capture leads
#   ☐ RESEND_API_KEY set
#   ☐ EMAIL_FROM points at a verified domain in Resend
#   ☐ WAITLIST_NOTIFY_EMAIL points at your inbox
#   ☐ Test: submit /#waitlist on prod, confirm both confirmation + notify emails arrive
#
# Step 3 — Take money
#   ☐ STRIPE_SECRET_KEY set (start with sk_test_, switch to sk_live_ on launch)
#   ☐ STRIPE_WEBHOOK_SECRET set (configure endpoint at dashboard.stripe.com/webhooks)
#   ☐ At least STRIPE_PRICE_STARTER_MONTHLY set (the Pro tier is what your first 10 will buy)
#   ☐ Test: end-to-end signup → checkout → webhook fires → subscription appears
#
# Step 4 — Verify a real post
#   ☐ DATABASE_URL set
#   ☐ npm run db:migrate    (run once to create tables)
#   ☐ OAUTH_IG_CLIENT_ID + OAUTH_IG_CLIENT_SECRET set (Instagram)
#   ☐ OAUTH_TT_CLIENT_ID + OAUTH_TT_CLIENT_SECRET set (TikTok)
#   ☐ WEBHOOK_VERIFY_TOKEN + WEBHOOK_SECRET set, endpoint registered with Meta
#   ☐ Test: submission with proof URL gets verified within ~5 min
#
# Each step builds on the previous. You can drive traffic after Step 2.
# Don't drive traffic before Step 1 — auth will 500.
# ═══════════════════════════════════════════════════════════════
