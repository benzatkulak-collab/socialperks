# ═══════════════════════════════════════════════════════════════
# SOCIAL PERKS — Environment Configuration
# Copy to .env and fill in your actual credentials.
# Variables marked [REQUIRED] must be set for production.
# Variables marked [OPTIONAL] have sensible defaults.
# ═══════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development                                              # [OPTIONAL] development | production | test
NEXT_PUBLIC_APP_URL=http://localhost:3000                         # [REQUIRED] Public-facing URL used for OAuth callbacks, emails, and widget embeds
# NEXT_PUBLIC_API_URL=                                            # [OPTIONAL] Override API base URL for frontend client (defaults to NEXT_PUBLIC_APP_URL)

# ── Auth ─────────────────────────────────────────────────────
AUTH_SECRET=                                                      # [REQUIRED] JWT signing secret — generate with: openssl rand -base64 32
CSRF_SECRET=                                                      # [OPTIONAL] CSRF token HMAC secret — defaults to AUTH_SECRET if omitted

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://socialperks:socialperks@localhost:5432/socialperks  # [REQUIRED] PostgreSQL connection string (Prisma-compatible)

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379                                  # [OPTIONAL] Redis connection URL for rate limiting, caching, and session store

# ── Stripe (Billing) ─────────────────────────────────────────
STRIPE_SECRET_KEY=                                                # [REQUIRED] Stripe secret key — sk_live_... or sk_test_...
STRIPE_WEBHOOK_SECRET=                                            # [REQUIRED] Stripe webhook signing secret — whsec_...
# STRIPE_PLATFORM_ACCOUNT_ID=                                    # [OPTIONAL] Platform Connect account ID (default: acct_platform_mock)
# STRIPE_PRICE_FREE=                                             # [OPTIONAL] Stripe price ID for the Free tier
# STRIPE_PRICE_STARTER=                                          # [OPTIONAL] Stripe price ID for Starter tier
# STRIPE_PRICE_PRO=                                              # [OPTIONAL] Stripe price ID for Pro tier
# STRIPE_PRICE_ENTERPRISE=                                       # [OPTIONAL] Stripe price ID for Enterprise tier
# STRIPE_PRICE_STARTER_MONTHLY=                                  # [OPTIONAL] Monthly billing price ID for Starter
# STRIPE_PRICE_STARTER_ANNUAL=                                   # [OPTIONAL] Annual billing price ID for Starter
# STRIPE_PRICE_PROFESSIONAL_MONTHLY=                             # [OPTIONAL] Monthly billing price ID for Professional
# STRIPE_PRICE_PROFESSIONAL_ANNUAL=                              # [OPTIONAL] Annual billing price ID for Professional
# STRIPE_PRICE_ENTERPRISE_MONTHLY=                               # [OPTIONAL] Monthly billing price ID for Enterprise
# STRIPE_PRICE_ENTERPRISE_ANNUAL=                                # [OPTIONAL] Annual billing price ID for Enterprise

# ── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY=                                                   # [OPTIONAL] Resend API key for transactional emails (signup, password reset, digests)
# EMAIL_FROM=Social Perks <noreply@socialperks.app>              # [OPTIONAL] Sender address for outgoing emails

# ── S3 / Object Storage ──────────────────────────────────────
S3_BUCKET=                                                        # [OPTIONAL] S3 bucket name for image uploads and proof attachments
S3_REGION=                                                        # [OPTIONAL] AWS region for the S3 bucket (e.g., us-east-1)
# S3_ACCESS_KEY_ID=                                              # [OPTIONAL] AWS access key (omit to use IAM role / instance profile)
# S3_SECRET_ACCESS_KEY=                                          # [OPTIONAL] AWS secret key (omit to use IAM role / instance profile)

# ── OAuth — Google ────────────────────────────────────────────
GOOGLE_CLIENT_ID=                                                 # [OPTIONAL] Google OAuth client ID for social login
GOOGLE_CLIENT_SECRET=                                             # [OPTIONAL] Google OAuth client secret

# ── OAuth — GitHub ────────────────────────────────────────────
GITHUB_CLIENT_ID=                                                 # [OPTIONAL] GitHub OAuth client ID for social login
GITHUB_CLIENT_SECRET=                                             # [OPTIONAL] GitHub OAuth client secret

# ── OAuth — Instagram ────────────────────────────────────────
# INSTAGRAM_CLIENT_ID=                                            # [OPTIONAL] Instagram Basic Display API client ID
# INSTAGRAM_CLIENT_SECRET=                                        # [OPTIONAL] Instagram Basic Display API client secret

# ── OAuth — TikTok ───────────────────────────────────────────
# TIKTOK_CLIENT_KEY=                                              # [OPTIONAL] TikTok for Developers client key
# TIKTOK_CLIENT_SECRET=                                           # [OPTIONAL] TikTok for Developers client secret

# ── OAuth — YouTube ──────────────────────────────────────────
# YOUTUBE_CLIENT_ID=                                              # [OPTIONAL] YouTube Data API client ID
# YOUTUBE_CLIENT_SECRET=                                          # [OPTIONAL] YouTube Data API client secret

# ── OAuth — X (Twitter) ─────────────────────────────────────
# X_CLIENT_ID=                                                    # [OPTIONAL] X (Twitter) OAuth 2.0 client ID
# X_CLIENT_SECRET=                                                # [OPTIONAL] X (Twitter) OAuth 2.0 client secret

# ── OAuth — Facebook ────────────────────────────────────────
# FACEBOOK_APP_ID=                                                # [OPTIONAL] Facebook App ID for login and page verification
# FACEBOOK_APP_SECRET=                                            # [OPTIONAL] Facebook App Secret

# ── OAuth — LinkedIn ────────────────────────────────────────
# LINKEDIN_CLIENT_ID=                                             # [OPTIONAL] LinkedIn OAuth client ID
# LINKEDIN_CLIENT_SECRET=                                         # [OPTIONAL] LinkedIn OAuth client secret

# ── Platform API Tokens ─────────────────────────────────────
# TELEGRAM_BOT_TOKEN=                                             # [OPTIONAL] Telegram bot token for submission verification
# TWITCH_CLIENT_ID=                                               # [OPTIONAL] Twitch app client ID for stream verification

# ── Infrastructure ───────────────────────────────────────────
# ALLOWED_ORIGINS=http://localhost:3000                           # [OPTIONAL] Comma-separated CORS allowed origins
# LOG_LEVEL=info                                                  # [OPTIONAL] Logging level: debug | info | warn | error
