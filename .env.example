# ═══════════════════════════════════════════════════════════════
# SOCIAL PERKS — Environment Configuration
# Copy to .env and fill in your actual credentials
# ═══════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://socialperks:socialperks@localhost:5432/socialperks

# ── Auth ─────────────────────────────────────────────────────
AUTH_SECRET=change-this-to-a-random-64-char-string-in-production

# ── Stripe (https://dashboard.stripe.com/apikeys) ───────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_PROFESSIONAL_MONTHLY=
STRIPE_PRICE_PROFESSIONAL_ANNUAL=
STRIPE_PRICE_ENTERPRISE_MONTHLY=
STRIPE_PRICE_ENTERPRISE_ANNUAL=

# Stripe price aliases (simplified, optional — map to monthly by default)
STRIPE_PRICE_FREE=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_ENTERPRISE=

# ── Email (https://resend.com/api-keys) ─────────────────────
RESEND_API_KEY=

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ═══════════════════════════════════════════════════════════════
# SOCIAL MEDIA PLATFORMS (25 platforms)
# Create developer accounts at each platform to get credentials
# ═══════════════════════════════════════════════════════════════

# ── Webhook verification ──────────────────────────────────────
WEBHOOK_VERIFY_TOKEN=

# ── 1. Instagram (https://developers.facebook.com) ──────────
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_WEBHOOK_SECRET=

# ── 2. TikTok (https://developers.tiktok.com) ───────────────
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
TIKTOK_WEBHOOK_SECRET=

# ── 3. Google / Google Maps / YouTube (https://console.cloud.google.com) ─
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── 4. Facebook (https://developers.facebook.com) ───────────
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_WEBHOOK_SECRET=

# ── 5. X / Twitter (https://developer.x.com) ────────────────
X_CLIENT_ID=
X_CLIENT_SECRET=
X_WEBHOOK_SECRET=

# ── 6. YouTube — uses Google credentials above ──────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_WEBHOOK_SECRET=

# ── 7. Yelp (https://www.yelp.com/developers) ───────────────
YELP_API_KEY=

# ── 8. LinkedIn (https://developer.linkedin.com) ────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── 9. Pinterest (https://developers.pinterest.com) ─────────
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=

# ── 10. Reddit (https://www.reddit.com/prefs/apps) ──────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── 11. Threads — uses Instagram/Meta credentials above ─────
THREADS_CLIENT_ID=
THREADS_CLIENT_SECRET=

# ── 12. Snapchat (https://kit.snapchat.com) ─────────────────
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=

# ── 13. TripAdvisor (https://developer-tripadvisor.com) ─────
TRIPADVISOR_API_KEY=

# ── 14. Nextdoor (https://developer.nextdoor.com) ───────────
NEXTDOOR_API_KEY=

# ── 15. Discord (https://discord.com/developers) ────────────
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ── 16. Twitch (https://dev.twitch.tv/console) ──────────────
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# ── 17. Tumblr (https://www.tumblr.com/oauth/apps) ──────────
TUMBLR_CLIENT_ID=
TUMBLR_CLIENT_SECRET=

# ── 18. WhatsApp Business (https://business.facebook.com) ───
WHATSAPP_BUSINESS_TOKEN=

# ── 19. Telegram (https://core.telegram.org/bots) ───────────
TELEGRAM_BOT_TOKEN=

# ── 20. BeReal — No public API available ─────────────────────
# Verification uses screenshot/URL matching only

# ── 21. Lemon8 — No public API available ─────────────────────
# Verification uses screenshot/URL matching only

# ── 22. Bluesky (https://bsky.app) ──────────────────────────
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# ── 23. Mastodon (your instance) ────────────────────────────
MASTODON_INSTANCE_URL=https://mastodon.social
MASTODON_CLIENT_ID=
MASTODON_CLIENT_SECRET=

# ── 24. Google Maps — uses Google credentials above ──────────
# Same GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET

# ── 25. Referral — internal, no API needed ───────────────────
# Uses in-app referral tracking only
