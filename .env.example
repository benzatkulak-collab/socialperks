# ═══════════════════════════════════════════════════════════════
# SOCIAL PERKS — Environment Configuration
# Copy to .env and fill in your actual credentials.
# Variables marked [REQUIRED] must be set for production.
# Variables marked [OPTIONAL] have sensible defaults.
# ═══════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development                                              # [OPTIONAL] development | production
# NEXT_PUBLIC_API_URL=                                            # [OPTIONAL] Override API base URL for frontend client

# ── Auth ─────────────────────────────────────────────────────
AUTH_SECRET=                                                      # [REQUIRED] JWT signing secret (generate: openssl rand -base64 32)
# CSRF_SECRET=                                                    # [OPTIONAL] CSRF token secret (defaults to AUTH_SECRET)

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://socialperks:socialperks@localhost:5432/socialperks  # [REQUIRED]

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=                                                # [REQUIRED] sk_live_... or sk_test_...
STRIPE_WEBHOOK_SECRET=                                            # [REQUIRED] whsec_...
# STRIPE_PLATFORM_ACCOUNT_ID=                                    # [OPTIONAL] Platform Connect account ID (default: acct_platform_mock)
# STRIPE_PRICE_FREE=                                             # [OPTIONAL] Stripe price IDs
# STRIPE_PRICE_STARTER=                                          # [OPTIONAL]
# STRIPE_PRICE_PRO=                                              # [OPTIONAL]
# STRIPE_PRICE_ENTERPRISE=                                       # [OPTIONAL]
# STRIPE_PRICE_STARTER_MONTHLY=                                  # [OPTIONAL]
# STRIPE_PRICE_STARTER_ANNUAL=                                   # [OPTIONAL]
# STRIPE_PRICE_PROFESSIONAL_MONTHLY=                             # [OPTIONAL]
# STRIPE_PRICE_PROFESSIONAL_ANNUAL=                              # [OPTIONAL]
# STRIPE_PRICE_ENTERPRISE_MONTHLY=                               # [OPTIONAL]
# STRIPE_PRICE_ENTERPRISE_ANNUAL=                                # [OPTIONAL]

# ── Email (Resend) ──────────────────────────────────────────
# RESEND_API_KEY=                                                 # [OPTIONAL] Resend API key for transactional email
# EMAIL_FROM=Social Perks <noreply@socialperks.app>              # [OPTIONAL] Sender address

# ── OAuth — Instagram ───────────────────────────────────────
# INSTAGRAM_CLIENT_ID=                                            # [OPTIONAL]
# INSTAGRAM_CLIENT_SECRET=                                        # [OPTIONAL]

# ── OAuth — TikTok ──────────────────────────────────────────
# TIKTOK_CLIENT_KEY=                                              # [OPTIONAL]
# TIKTOK_CLIENT_SECRET=                                           # [OPTIONAL]

# ── OAuth — YouTube ─────────────────────────────────────────
# YOUTUBE_CLIENT_ID=                                              # [OPTIONAL]
# YOUTUBE_CLIENT_SECRET=                                          # [OPTIONAL]

# ── OAuth — X (Twitter) ─────────────────────────────────────
# X_CLIENT_ID=                                                    # [OPTIONAL]
# X_CLIENT_SECRET=                                                # [OPTIONAL]

# ── OAuth — Facebook ────────────────────────────────────────
# FACEBOOK_APP_ID=                                                # [OPTIONAL]
# FACEBOOK_APP_SECRET=                                            # [OPTIONAL]

# ── OAuth — LinkedIn ────────────────────────────────────────
# LINKEDIN_CLIENT_ID=                                             # [OPTIONAL]
# LINKEDIN_CLIENT_SECRET=                                         # [OPTIONAL]

# ── Platform API Tokens ─────────────────────────────────────
# TELEGRAM_BOT_TOKEN=                                             # [OPTIONAL] Telegram bot token for verification
# TWITCH_CLIENT_ID=                                               # [OPTIONAL] Twitch app client ID

# ── Infrastructure (used by docker-compose) ─────────────────
# REDIS_URL=redis://localhost:6379                                # [OPTIONAL] Redis connection URL
# ALLOWED_ORIGINS=http://localhost:3000                           # [OPTIONAL] CORS allowed origins
